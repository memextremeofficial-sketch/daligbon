<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetBackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1E3A8A">

    <TextView
        android:id="@+id/widgetSeason"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WINTER RECIPE"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#FBBF24"
        android:textAllCaps="true"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/widgetTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recipe of the Day"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/widgetDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="A tasty daily recipe recommendation to cook today."
        android:textSize="13sp"
        android:textColor="#E0E7FF"
        android:maxLines="2"
        android:ellipsize="end"/>
</LinearLayout>
