<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Recipe"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1F2937"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today's Featured Recipe:"
        android:textSize="16sp"
        android:textColor="#4B5563"
        android:layout_marginBottom="8dp"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvTodayRecipe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvTodaySeason"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Season: Winter"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#D97706"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvTodayTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recipe Title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvTodayDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recipe description goes here..."
                android:textSize="15sp"
                android:textColor="#4B5563"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to view full recipe →"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2563EB"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnViewAll"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Browse All Recipes"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2563EB"
        app:cornerRadius="12dp"/>
</LinearLayout>
